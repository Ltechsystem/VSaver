<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ValheimSync.App.ViewModels"
        x:Class="ValheimSync.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="VSaver — shared world sync"
        Icon="/app.ico"
        Width="760" Height="560"
        MinWidth="600" MinHeight="440">

    <Window.Styles>
        <!-- Green Play / red Done buttons in the server list (hold color on hover/press). -->
        <Style Selector="Button.play">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.play:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#388E3C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.play:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1B5E20"/>

            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.done">
            <Setter Property="Background" Value="#C62828"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.done:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.done:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#B71C1C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto,140" Margin="16">

        <!-- Connection + first-run setup -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
            <TextBlock Grid.Column="0" Text="Your name:" VerticalAlignment="Center" Margin="0,0,8,0"/>

            <!-- Display mode: name as plain text with a pen to edit -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center" IsVisible="{Binding !IsEditingName}">
                <TextBlock Text="{Binding PlayerName}" VerticalAlignment="Center"
                           FontWeight="SemiBold" IsVisible="{Binding HasName}"/>
                <TextBlock Text="signing in to Google…" VerticalAlignment="Center"
                           Opacity="0.7" FontStyle="Italic" IsVisible="{Binding !HasName}"/>
                <Button Content="✎" ToolTip.Tip="Change your name"
                        Command="{Binding EditNameCommand}" IsVisible="{Binding HasName}"
                        Background="Transparent" BorderThickness="0" Padding="6,2"/>
            </StackPanel>

            <!-- Edit mode: text box (first-time fallback or the pen) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center" IsVisible="{Binding IsEditingName}">
                <TextBox Width="220" Text="{Binding NameDraft}" Watermark="Your name"
                         VerticalAlignment="Center">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SaveNameCommand}"/>
                    </TextBox.KeyBindings>
                </TextBox>
                <Button Content="Save" Command="{Binding SaveNameCommand}"/>
                <Button Content="Cancel" Command="{Binding CancelNameEditCommand}"
                        IsVisible="{Binding HasName}"/>
            </StackPanel>

            <Button    Grid.Column="2" Content="Connect"
                       Command="{Binding ConnectCommand}"
                       ToolTip.Tip="Enter your server folder ID below, then connect"
                       IsVisible="{Binding !IsConnected}"/>
            <Button    Grid.Column="3" Content="Log out"
                       Margin="8,0,0,0"
                       ToolTip.Tip="Disconnect and sign in with a different Google account"
                       Command="{Binding LogoutCommand}"
                       IsVisible="{Binding IsConnected}"/>
        </Grid>

            <!-- Shared Drive folder id: entered once, hidden after connecting. -->
            <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding !IsConnected}">
                <TextBlock Grid.Column="0" Text="Server folder ID:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding DriveFolderId}"
                         Watermark="Paste the shared Google Drive folder ID your group gave you"
                         VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- Toolbar (disabled until a username exists) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12"
                    VerticalAlignment="Center" IsEnabled="{Binding HasName}">
            <Button Content="▶ Play Valheim"
                    Classes="accent"
                    Command="{Binding LaunchValheimCommand}"
                    ToolTip.Tip="Launch Valheim through Steam"/>
            <Button Content="Sync now" Command="{Binding SyncNowCommand}"/>
            <Button Content="Refresh"
                    Command="{Binding RescanWorldsCommand}"
                    ToolTip.Tip="Reload the server list from the cloud"/>
            <Border Width="1" Margin="4,2" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <ComboBox ItemsSource="{Binding AddableWorlds}"
                      SelectedItem="{Binding SelectedAddableWorld}"
                      PlaceholderText="local world…"
                      MinWidth="150"
                      IsEnabled="{Binding IsConnected}"
                      ToolTip.Tip="A local world to publish as a shared server"/>
            <Button Content="Add server"
                    Command="{Binding AddServerCommand}"
                    ToolTip.Tip="Upload the selected local world to the cloud so everyone can play it"/>
        </StackPanel>

        <!-- World list (disabled until a username exists) -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,0,12"
                IsEnabled="{Binding HasName}">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Worlds}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorldItemViewModel">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto"
                                  Margin="8,6">
                                <CheckBox  Grid.Column="0" IsChecked="{Binding IsSelected}"
                                           ToolTip.Tip="Sync this world" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                           VerticalAlignment="Center" Opacity="0.7" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="3" Text="{Binding StatusDisplay}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="4" Text="{Binding LockDisplay}"
                                           VerticalAlignment="Center" Opacity="0.8" Margin="0,0,12,0"/>
                                <Button    Grid.Column="5" Content="Play" Margin="0,0,12,0"
                                           Classes="play"
                                           IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).ShowPlayButtons}"
                                           ToolTip.Tip="Take the lock so no one else plays over you"
                                           Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).AcquireLockCommand}"
                                           CommandParameter="{Binding}"/>
                                <Button    Grid.Column="6" Content="Done"
                                           Classes="done"
                                           IsVisible="{Binding ShowDone}"
                                           ToolTip.Tip="Upload final save and hand the world back"
                                           Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).ReleaseLockCommand}"
                                           CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Status line -->
        <TextBlock Grid.Row="3" Text="{Binding StatusText}" Opacity="0.85" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <!-- Activity log -->
        <Border Grid.Row="4" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6" Padding="4">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding LogLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{Binding}" FontFamily="Consolas,Menlo,monospace"
                                       FontSize="12" Margin="4,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
